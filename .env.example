# Copy to `.env` and fill in. `.env` is git-ignored — never commit real secrets.

# Discord bot token (Developer Portal → your app → Bot → Reset Token).
DISCORD_TOKEN=

# Anthropic API key. One key, or several comma-separated for the key pool (ARCHITECTURE.md §9.1).
ANTHROPIC_API_KEY=

# Character name. To rename the bot, change this AND the bot's username in the Developer Portal.
BOT_NAME=썩스가재

# Bot language for user-facing strings (ARCHITECTURE.md §10). Ships with `ko` and `en`.
# Default `ko` preserves the original language. Note: the persona voice comes from persona.md.
BOT_LOCALE=ko

# Discord guild (server) id for admin slash-command registration (ralplan S1).
# Right-click your server → Copy Server ID (Developer Mode on). Required to run the bot.
ADMIN_GUILD_ID=

# Designated admin role id (ralplan S2). Members with this role may command privileged
# actions (channel/role/category/moderation). Required. Right-click the role → Copy Role ID.
ADMIN_ROLE_ID=

# --- Onboarding (ralplan S6) — optional; activates only when set ---
# WELCOME_CHANNEL_ID=        # channel id to post the join welcome message in
# WELCOME_MESSAGE=           # join text ({name} = display name). Empty → BOT_LOCALE default greeting
# DEFAULT_ROLE_ID=           # role id auto-assigned to new members on join

# --- Memory (M2) ---
# Embedding provider: local | voyage | openai.
#   local  = offline, NON-semantic — for testing the pipeline without a key (default).
#   voyage/openai = real semantic memory; requires EMBEDDING_API_KEY below.
EMBEDDING_PROVIDER=local
EMBEDDING_API_KEY=
# EMBEDDING_MODEL=            # empty → provider default (voyage-3 / text-embedding-3-small)

# --- Optional overrides (defaults shown) ---
# MODEL=claude-sonnet-4-6
# INGEST_MODEL=claude-haiku-4-5-20251001
# MAX_TOKENS=600
# MAX_INPUT_CHARS=4000
# RECENT_BUFFER_SIZE=12
# 독점 완화 넛지 (anti-fatigue): 한 명이 채널에서 봇을 계속 독점하면 divider(절취선)/thread(스레드 이동)/off
# NUDGE_STYLE=divider
# MEMORY_DB=data/memory.db
# RETRIEVAL_TOP_N=6
# HALF_LIFE_BASE_DAYS=3.0
# DEDUP_THRESHOLD=0.86

# --- Activity leveling (G001-G004) ---
# LEVELING_DB=data/leveling.db   # separate file from memory.db (lock-domain isolation)
# Per-guild leveling on/off, cooldown, and top-N are set at runtime via admin slash commands.

# --- Background jobs (M3 forgetting / M4 growth) ---
# ENABLE_BACKGROUND_JOBS=true
# PRUNE_INTERVAL_HOURS=24
# REFLECT_INTERVAL_HOURS=24
# RETENTION_THRESHOLD=0.05
# MAX_DELETE_RATIO=0.2
# FORGET_MODE=delete            # delete | blur
# REFLECT_MIN_EPISODICS=5

# COOLDOWN_SECONDS=3
# LOG_LEVEL=INFO
# PERSONA_FILE=persona.md
